{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "types": ["node"],
    "paths": {
      "chunk-your-tools": ["../../typescript/src/index.ts"]
    },
    "typeRoots": [
      "../../typescript/node_modules/@types",
      "./node_modules/@types"
    ]
  },
  "include": ["test/**/*.mjs"]
}
